<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>netstandard2.1</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <PropertyGroup>
    <PackageId>Azure.Monitor.OpenTelemetry.Profiler</PackageId>
    <PackageTags>Microsoft Azure Monitor OpenTelemetry Profiler ASP.NET Performance</PackageTags>
    <Description>Library for Azure Monitor OpenTelemetry Profiler for ASP.NET Core.</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageIcon>icon.png</PackageIcon>
    <PackageReadmeFile>Readme.md</PackageReadmeFile>
  </PropertyGroup>

  <!-- Bundle project-reference DLLs into the package (they are not published as separate NuGet packages) -->
  <ItemGroup>
    <ProjectReference Include="..\Azure.Monitor.OpenTelemetry.Profiler.Core\Azure.Monitor.OpenTelemetry.Profiler.Core.csproj" PrivateAssets="all" />
  </ItemGroup>

  <!-- Transitive NuGet dependencies (must be declared explicitly because project refs use PrivateAssets=all) -->
  <ItemGroup>
    <PackageReference Include="Azure.Core" />
    <PackageReference Include="Azure.Identity" />
    <PackageReference Include="Azure.Monitor.OpenTelemetry.Exporter" />
    <PackageReference Include="Microsoft.Bcl.AsyncInterfaces" />
    <PackageReference Include="Microsoft.Diagnostics.NETCore.Client" />
    <PackageReference Include="Microsoft.Extensions.Configuration" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Binder" />
    <PackageReference Include="Microsoft.Extensions.Hosting.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Logging" />
    <PackageReference Include="Microsoft.Extensions.Options.ConfigurationExtensions" />
    <PackageReference Include="System.Collections.Immutable" />
    <PackageReference Include="System.Diagnostics.PerformanceCounter" />
    <PackageReference Include="System.IO.Hashing" />
    <PackageReference Include="System.Linq.AsyncEnumerable" />
    <PackageReference Include="System.Memory.Data" />
    <PackageReference Include="System.Security.Cryptography.ProtectedData" />
    <PackageReference Include="System.Text.Json" />
  </ItemGroup>

  <!-- Package content: Uploader, Readme, Icon -->
  <ItemGroup>
    <None Include="obj\$(Configuration)\Uploader\Uploader.zip" Pack="true" PackagePath="contentFiles\any\any\ServiceProfiler\TraceUpload.zip" PackageCopyToOutput="true" PackageFlatten="true" />
    <None Include="..\Readme.md" Pack="true" PackagePath="" />
    <None Include="..\..\..\images\icon.png" Pack="true" PackagePath="" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Azure.Monitor.OpenTelemetry.Profiler.Tests" Key="$(TestPublicKey)" />
  </ItemGroup>

  <!-- Include DLLs, XML docs, and symbols from project references in the package -->
  <PropertyGroup>
    <TargetsForTfmSpecificBuildOutput>$(TargetsForTfmSpecificBuildOutput);IncludeProjectReferenceDlls</TargetsForTfmSpecificBuildOutput>
  </PropertyGroup>

  <Target Name="IncludeProjectReferenceDlls" DependsOnTargets="ResolveReferences">
    <ItemGroup>
      <!-- DLLs from project references -->
      <BuildOutputInPackage Include="@(ReferenceCopyLocalPaths)"
        Condition="'%(ReferenceCopyLocalPaths.ReferenceSourceTarget)' == 'ProjectReference'" />
      <!-- XML documentation files (derived from DLL paths) -->
      <BuildOutputInPackage Include="@(ReferenceCopyLocalPaths->'%(RootDir)%(Directory)%(Filename).xml')"
        Condition="'%(ReferenceCopyLocalPaths.ReferenceSourceTarget)' == 'ProjectReference' AND Exists('%(RootDir)%(Directory)%(Filename).xml')" />
      <!-- PDBs go into snupkg automatically when SymbolPackageFormat=snupkg -->
      <BuildOutputInPackage Include="@(ReferenceCopyLocalPaths->'%(RootDir)%(Directory)%(Filename).pdb')"
        Condition="'%(ReferenceCopyLocalPaths.ReferenceSourceTarget)' == 'ProjectReference' AND Exists('%(RootDir)%(Directory)%(Filename).pdb')" />
    </ItemGroup>
  </Target>
</Project>
