<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>netstandard2.1</TargetFramework>
    <AssemblyName>Microsoft.ApplicationInsights.Profiler.Core</AssemblyName>
    <RootNamespace>Microsoft.ApplicationInsights.Profiler.Core</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Microsoft.ApplicationInsights.Profiler.AspNetCore" />
    <InternalsVisibleTo Include="Microsoft.ServiceProfiler.EventPipe.Orchestration" />

    <InternalsVisibleTo Include="ServiceProfiler.EventPipe.ApplicationInsights.Profiler.Tests" Key="$(TestPublicKey)"/>
    <InternalsVisibleTo Include="ServiceProfiler.EventPipe.Client.Tests" Key="$(TestPublicKey)" />
    <InternalsVisibleTo Include="DynamicProxyGenAssembly2" Key="$(CastleCorePublicKey)" />
  </ItemGroup>

  <PropertyGroup Condition=" '$(IsSpOfficialBuild)' == 'true' ">
    <!--Only generate NuGet packages on server build-->
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
  </PropertyGroup>

  <!--NuGet package properties-->
  <PropertyGroup>
    <Version Condition=" '$(Version)' == '' ">1.0.0</Version>
    <PackageId>Microsoft.ApplicationInsights.Profiler.Core</PackageId>
    <Description>Core Library for Microsoft Application Insights Profiler.</Description>
    <PackageTags>Microsoft Azure ServiceProfiler Linux</PackageTags>
    <PackageLicenseFile>EULA.md</PackageLicenseFile>
    <PackageIcon>icon.png</PackageIcon>
  </PropertyGroup>

  <PropertyGroup>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>

  <!-- Transitive NuGet dependencies (must be declared explicitly because project refs use PrivateAssets=all) -->
  <ItemGroup>
    <PackageReference Include="Azure.Core" />
    <PackageReference Include="Azure.Identity" />
    <PackageReference Include="CommandLineParser" />
    <PackageReference Include="Microsoft.ApplicationInsights.AspNetCore" VersionOverride="[2.23.0, 3.0.0)" />
    <PackageReference Include="Microsoft.ApplicationInsights" VersionOverride="[2.23.0, 3.0.0)" />
    <PackageReference Include="Microsoft.ApplicationInsights.DependencyCollector" VersionOverride="[2.23.0, 3.0.0)" />
    <PackageReference Include="Microsoft.ApplicationInsights.PerfCounterCollector" VersionOverride="[2.23.0, 3.0.0)" />
    <PackageReference Include="Microsoft.ApplicationInsights.WindowsServer" VersionOverride="[2.23.0, 3.0.0)" />
    <PackageReference Include="Microsoft.ApplicationInsights.WindowsServer.TelemetryChannel" VersionOverride="[2.23.0, 3.0.0)" />
    <PackageReference Include="Microsoft.Extensions.Logging.ApplicationInsights" VersionOverride="[2.23.0, 3.0.0)" />
    <PackageReference Include="Microsoft.AspNetCore.Http" />
    <PackageReference Include="Microsoft.Bcl.AsyncInterfaces" />
    <PackageReference Include="Microsoft.Bcl.Memory" />
    <PackageReference Include="Microsoft.Diagnostics.NETCore.Client" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Json" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" />
    <PackageReference Include="Microsoft.Extensions.Hosting.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Logging.Debug" />
    <PackageReference Include="Microsoft.Extensions.Options" />
    <PackageReference Include="System.Collections.Immutable" />
    <PackageReference Include="System.Diagnostics.PerformanceCounter" />
    <PackageReference Include="System.IdentityModel.Tokens.Jwt" />
    <PackageReference Include="System.IO.Hashing" />
    <PackageReference Include="System.Linq.AsyncEnumerable" />
    <PackageReference Include="System.Memory.Data" />
    <PackageReference Include="System.Security.Cryptography.ProtectedData" />
    <PackageReference Include="System.Text.Encodings.Web" />
    <PackageReference Include="System.Text.Json" />
    <PackageReference Include="System.ValueTuple" />
  </ItemGroup>

  <!-- Project references bundled into this package (not published as separate NuGet packages) -->
  <ItemGroup>
    <ProjectReference Include="..\..\Azure.Monitor.Diagnostics.Profiler\Azure.Monitor.Diagnostics.Profiler.csproj" PrivateAssets="all" />
    <ProjectReference Include="..\..\Microsoft.ApplicationInsights.Profiler.Shared\Microsoft.ApplicationInsights.Profiler.Shared.csproj" PrivateAssets="all" />
    <ProjectReference Include="..\..\ServiceProfiler.Utilities\ServiceProfiler.Utilities.csproj" PrivateAssets="all" />
    <ProjectReference Include="..\ServiceProfiler.EventPipe.Logging\ServiceProfiler.EventPipe.Logging.csproj" PrivateAssets="all" />
    <ProjectReference Include="..\..\Microsoft.ServiceProfiler.Orchestration\Microsoft.ServiceProfiler.Orchestration.csproj" PrivateAssets="all" />
  </ItemGroup>

  <!-- Package content: License, Icon -->
  <ItemGroup>
    <None Include="..\ReleaseResources\EULA.md" Pack="true" PackagePath="" />
    <None Include="..\ReleaseResources\icon.png" Pack="true" PackagePath="" />
  </ItemGroup>

  <!-- Include DLLs, XML docs, and symbols from project references in the package -->
  <PropertyGroup>
    <TargetsForTfmSpecificBuildOutput>$(TargetsForTfmSpecificBuildOutput);IncludeProjectReferenceDlls</TargetsForTfmSpecificBuildOutput>
  </PropertyGroup>

  <Target Name="IncludeProjectReferenceDlls" DependsOnTargets="ResolveReferences">
    <ItemGroup>
      <!-- DLLs from project references -->
      <BuildOutputInPackage Include="@(ReferenceCopyLocalPaths)"
        Condition="'%(ReferenceCopyLocalPaths.ReferenceSourceTarget)' == 'ProjectReference'" />
      <!-- XML documentation files (derived from DLL paths) -->
      <BuildOutputInPackage Include="@(ReferenceCopyLocalPaths->'%(RootDir)%(Directory)%(Filename).xml')"
        Condition="'%(ReferenceCopyLocalPaths.ReferenceSourceTarget)' == 'ProjectReference' AND Exists('%(RootDir)%(Directory)%(Filename).xml')" />
      <!-- PDBs go into snupkg automatically when SymbolPackageFormat=snupkg -->
      <BuildOutputInPackage Include="@(ReferenceCopyLocalPaths->'%(RootDir)%(Directory)%(Filename).pdb')"
        Condition="'%(ReferenceCopyLocalPaths.ReferenceSourceTarget)' == 'ProjectReference' AND Exists('%(RootDir)%(Directory)%(Filename).pdb')" />
    </ItemGroup>
  </Target>
</Project>
