<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>Azure.Monitor.OpenTelemetry.Profiler.SiteExtension</id>
    <version>$version$</version>
    <title>Azure Monitor Profiler (Codeless)</title>
    <authors>Microsoft</authors>
    <owners>Microsoft,MicrosoftServiceProfiler</owners>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <projectUrl>https://github.com/Azure/azuremonitor-opentelemetry-profiler-net</projectUrl>
    <description>
      Codeless Azure App Service (Windows) Site Extension that enables the Azure Monitor profiler without
      any code change, NuGet reference, or recompile. It injects an ASP.NET Core HostingStartup that
      detects whether the application uses OpenTelemetry or the classic Application Insights SDK and
      enables the matching profiler. PROOF OF CONCEPT.
    </description>
    <summary>Codeless Azure Monitor profiler enablement for Windows App Service (POC).</summary>
    <tags>AzureSiteExtension Azure Monitor OpenTelemetry Profiler Performance ApplicationInsights AspNetCore</tags>
  </metadata>
  <files>
    <!-- Everything under staging (applicationHost.xdt + payload) becomes the extension's content. -->
    <file src="staging\**" target="content" exclude="**\*.pdb" />
  </files>
</package>
